<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFBF7"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#1D3557"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/machine_subtitle"
        android:textColor="#5C677D"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnViewHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:backgroundTint="#457B9D"
        android:text="@string/order_history_title"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/txtEmptyMachines"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="#8D99AE"
        android:textSize="14sp" />

    <ListView
        android:id="@+id/listMachines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:divider="#D9D9D9"
        android:dividerHeight="1dp" />
</LinearLayout>
