<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F0"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/customer_self_service_title"
            android:textColor="#1D3557"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/customer_self_service_subtitle"
            android:textColor="#4A5568"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtSelectedMachine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#C86B3C"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/customer_self_service_machine_header"
            android:textColor="#1D3557"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEmptySelfServiceMachines"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#4A5568"
            android:textSize="15sp" />

        <ListView
            android:id="@+id/listSelfServiceMachines"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:choiceMode="singleChoice"
            android:dividerHeight="1dp" />

        <EditText
            android:id="@+id/edtSelfServiceCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#FFFFFF"
            android:hint="@string/customer_name"
            android:inputType="textPersonName"
            android:padding="16dp" />

        <EditText
            android:id="@+id/edtSelfServiceCustomerPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:hint="@string/customer_phone"
            android:inputType="phone"
            android:padding="16dp" />

        <Spinner
            android:id="@+id/spinnerSelfServicePaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnSelfServicePay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2A9D8F"
            android:text="@string/customer_self_service_pay"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
