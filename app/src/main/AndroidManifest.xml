<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.laundromat.pos">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LaundromatPos">
        <activity
            android:name=".ui.customer.CustomerSelfServiceActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name=".ui.history.OrderHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.checkout.CheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".ui.machine.MachineListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
